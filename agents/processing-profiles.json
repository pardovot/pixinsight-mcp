{
  "planetary_nebula": {
    "description": "Small, round, faint shells. M97 (Owl), M27 (Dumbbell), M57 (Ring), NGC 7293 (Helix)",
    "characteristics": {
      "typical_size": "small",
      "dynamic_range": "low",
      "has_bright_core": false,
      "color_signature": "emission",
      "star_density": "moderate"
    },
    "stretch": {
      "target_median": 0.11,
      "headroom": 0.08
    },
    "tools": {
      "GC": { "use": true },
      "ABE": { "use": "try", "reason": "Compare with GC if gradients persist" },
      "BXT": { "use": true, "correct_only": true },
      "SPCC": { "use": true },
      "SCNR": { "use": "try", "reason": "Only if SPCC fails" },
      "NXT": { "use": true, "denoise_linear": 0.20, "denoise_post_stretch": 0.25 },
      "SXT": { "use": true, "safe": true },
      "LHE": { "use": true, "start_amount": 0.35, "start_radius": 64, "mask_blur": 8, "mask_clipLow": 0.06 },
      "HDRMT": { "use": "core_only", "inverted": true, "layers": 5, "iterations": 1, "reason": "Apply ONLY through core zone mask — compresses core dynamic range to reveal detail. Do NOT apply globally (flattens faint structure). v7-v9 showed core burns without it." },
      "LRGB": { "use": "avoid", "reason": "v3 showed native LRGB crushes PN brightness. Use RGB-only + PixelMath L enhancement instead." },
      "Ha_injection": { "use": true, "reason": "MANDATORY for HaLRGB — enhances shell structure. Use max_output=0.85 to prevent R burning." }
    },
    "saturation": {
      "rgb_initial": 0.75,
      "composition_target": 0.85,
      "hue_selective": true,
      "max_p90": 0.80
    },
    "burn": {
      "max_bright_block_pct": 3.0
    },
    "stars": {
      "screen_blend_strength": 1.00,
      "prominence": "prominent"
    },
    "notes": "Focus on revealing internal structure (eyes, shells) AND outer halo. Color is teal/blue for OIII-dominant + red/pink for Ha. OUTER HALO is a key differentiator — apply shadow-lifting curves through inverted luminance mask to make it OBVIOUSLY visible. Push OIII saturation hard (blue/teal). Background should reveal faint outer structure, not be crushed to black. RGB-only + PixelMath L enhancement preferred over native LRGB (which crushes brightness).",
    "learned_overrides": {
      "avoid_native_lrgb": true,
      "shadow_lift_mandatory": true,
      "oiii_saturation_push": "aggressive"
    }
  },

  "galaxy_spiral": {
    "description": "Face-on spiral. M81, M51, M33, M101, M106",
    "characteristics": {
      "typical_size": "large",
      "dynamic_range": "high",
      "has_bright_core": true,
      "color_signature": "broadband",
      "star_density": "moderate"
    },
    "stretch": {
      "target_median": 0.08,
      "headroom": 0.12
    },
    "tools": {
      "GC": { "use": true },
      "ABE": { "use": "try", "reason": "Compare with GC — ABE deg2 often gentler for galaxies" },
      "BXT": { "use": true, "correct_only": true },
      "SPCC": { "use": true },
      "SCNR": { "use": "try", "reason": "Only if SPCC fails, amount 0.30-0.35" },
      "NXT": { "use": true, "denoise_linear": 0.18, "denoise_post_stretch": 0.25 },
      "SXT": { "use": true, "safe": false, "caution": "Leaves residuals on HII regions and spiral knots" },
      "LHE": { "use": true, "start_amount": 0.20, "start_radius": 128, "mask_blur": 6, "mask_clipLow": 0.10, "mask_gamma": 2.0 },
      "HDRMT": { "use": true, "inverted": true, "layers": 6, "iterations": 1, "mask_clipLow": 0.30, "reason": "Essential for core and arm detail" },
      "LRGB": { "use": true, "lightness": 0.55, "saturation": 0.80 },
      "Ha_injection": { "use": "try", "reason": "Useful for HII regions if Ha data available", "strength": 0.25 }
    },
    "saturation": {
      "rgb_initial": 0.68,
      "composition_target": 0.75,
      "hue_selective": true,
      "blue_boost": 1.30,
      "pink_boost": 1.25,
      "max_p90": 0.75
    },
    "burn": {
      "max_bright_block_pct": 3.0
    },
    "stars": {
      "screen_blend_strength": 0.85,
      "prominence": "subdued",
      "stretch_midtone": 0.22,
      "stretch_iterations": 5,
      "saturation_curves": 1,
      "rolloff_knee": 0.65,
      "notes": "Galaxies need controlled stars. Use midtone 0.22 and 5 iterations (not 0.15/6 which bloats). Single saturation curve. Blend at 0.85 max."
    },
    "notes": "Dark background (0.08-0.10). IFN may be present — preserve with gentle shadow handling. Dust lanes and spiral arms are primary detail targets. Core easily clips — use headroom. Push saturation — galaxies should have warm, vivid colors. Stars must be TIGHT and subdued — do NOT use aggressive star stretch (midtone < 0.20 or iterations > 5 will bloat stars).",
    "learned_overrides": {}
  },

