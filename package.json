{
  "name": "@pardovot/pixinsight-mcp",
  "version": "0.8.0",
  "description": "MCP server bridging AI assistants with PixInsight for astrophotography processing",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pixinsight-mcp": "build/index.js",
    "pixinsight-mcp-install": "install-watcher.mjs",
    "pixinsight-mcp-watch": "start-watcher-instance.mjs"
  },
  "files": [
    "build",
    "pjsr",
    "install-watcher.mjs",
    "start-watcher-instance.mjs",
    "README.md",
    "LICENSE"
  ],
  "author": "Alain Escaffre (original); packaged by pardovot",
  "homepage": "https://github.com/pardovot/pixinsight-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pardovot/pixinsight-mcp.git"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "watch": "node start-watcher-instance.mjs",
    "setup-bridge": "node -e \"const fs=require('fs'),os=require('os'),p=require('path'),b=p.join(os.homedir(),'.pixinsight-mcp');['bridge/commands','bridge/results','bridge/logs','catalog/recipes'].forEach(d=>fs.mkdirSync(p.join(b,d),{recursive:true}))\"",
    "module:config": "node module/config.mjs",
    "module:pcl": "node module/build-pcl.mjs",
    "module:build": "node module/build.mjs",
    "module:sign": "node module/sign.mjs",
    "module:install": "node module/install.mjs",
    "repo:build": "node scripts/build-pi-repo.mjs"
  },
  "keywords": [
    "pixinsight",
    "mcp",
    "astrophotography",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
