{
  "name": "@pardovot/pixinsight-mcp",
  "version": "0.1.0",
  "description": "MCP server bridging AI assistants with PixInsight for astrophotography processing",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "pixinsight-mcp": "build/index.js"
  },
  "files": [
    "build",
    "pjsr",
    "README.md",
    "LICENSE"
  ],
  "author": "Alain Escaffre (original); packaged by pardovot",
  "homepage": "https://github.com/aescaffre/pixinsight-mcp",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "setup-bridge": "node -e \"const fs=require('fs'),os=require('os'),p=require('path'),b=p.join(os.homedir(),'.pixinsight-mcp');['bridge/commands','bridge/results','bridge/logs','catalog/recipes'].forEach(d=>fs.mkdirSync(p.join(b,d),{recursive:true}))\"",
    "editor": "node editor/server.mjs"
  },
  "keywords": [
    "pixinsight",
    "mcp",
    "astrophotography",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@mistralai/mistralai": "^1.15.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cross-spawn": "^7.0.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
